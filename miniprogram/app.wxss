/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 16px;
  color: #333;
  background-color: #f5f5f5;
}

.container {
  padding: 20px;
  min-height: 100vh;
  box-sizing: border-box;
}

.btn-primary {
  background-color: #007AFF;
  color: #fff;
  border-radius: 8px;
  padding: 12px 0;
  text-align: center;
  font-size: 16px;
  border: none;
}

.btn-primary:active {
  opacity: 0.8;
}

.btn-primary[disabled] {
  background-color: #ccc;
}
