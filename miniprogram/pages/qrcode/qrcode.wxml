<!-- 动态二维码页 -->
<view class="container">
  <view class="qrcode-card">
    <view class="card-header">
      <text class="card-icon">🎫</text>
      <text class="card-title">签到凭证</text>
    </view>

    <view class="tips-text">请向工作人员出示此二维码完成核销</view>

    <!-- 二维码展示区：直接用 canvas 展示 -->
    <view class="qrcode-wrapper">
      <canvas canvas-id="qrcode-canvas" class="qrcode-canvas" />
      <view wx:if="{{!qrReady}}" class="qrcode-loading">
        <text>生成中...</text>
      </view>
    </view>

    <!-- 刷新倒计时 -->
    <view class="refresh-info">
      <text class="countdown-text">🔄 {{countdown}} 秒后自动刷新</text>
    </view>

    <!-- 防转发提示 -->
    <view class="security-tip">
      <text class="tip-icon">🔒</text>
      <text class="tip-text">动态二维码，截图转发无效</text>
    </view>

    <!-- 手动刷新按钮 -->
    <button class="btn-refresh" bindtap="manualRefresh">手动刷新二维码</button>
  </view>
</view>
