/* 管理员验证 */
.auth-card {
  background: #fff; border-radius: 12px; padding: 40px 24px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08); text-align: center;
}
.auth-icon { font-size: 48px; margin-bottom: 16px; }
.auth-title { font-size: 20px; font-weight: 600; color: #333; margin-bottom: 8px; }
.auth-desc { font-size: 14px; color: #999; margin-bottom: 24px; }
.auth-input {
  width: 100%; height: 46px; border: 1px solid #e0e0e0;
  border-radius: 8px; padding: 0 14px; font-size: 15px;
  text-align: center; box-sizing: border-box; margin-bottom: 16px;
}
.auth-input:focus { border-color: #007AFF; }
.btn-auth { width: 100%; background: #007AFF; color: #fff; border-radius: 8px; padding: 12px 0; font-size: 16px; }
.btn-auth:active { opacity: 0.85; }
.auth-hint { font-size: 12px; color: #bbb; margin-top: 14px; }

/* 二维码卡片 */
.container { padding: 30px 20px; }
.qrcode-card {
  background: #fff; border-radius: 12px; padding: 28px 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08); text-align: center;
}
.card-header { display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }
.card-icon { font-size: 24px; margin-right: 8px; }
.card-title { font-size: 22px; font-weight: 600; color: #333; }
.tips-text { font-size: 14px; color: #888; margin-bottom: 24px; }

.qrcode-wrapper { display: flex; justify-content: center; margin-bottom: 20px; min-height: 220px; }
.qrcode-image { width: 220px; height: 220px; }
.qrcode-loading {
  width: 220px; height: 220px; display: flex; align-items: center;
  justify-content: center; background: #f5f5f5; border-radius: 8px;
  font-size: 14px; color: #999;
}

.refresh-info { background: #f0f7ff; border-radius: 8px; padding: 10px 16px; margin-bottom: 16px; }
.countdown-text { font-size: 15px; color: #007AFF; font-weight: 500; }

.security-tip {
  display: flex; align-items: center; justify-content: center;
  background: #fff9e6; border: 1px solid #ffe8a1;
  border-radius: 8px; padding: 10px 16px; margin-bottom: 20px;
}
.tip-icon { font-size: 16px; margin-right: 6px; }
.tip-text { font-size: 13px; color: #b8860b; }

.btn-refresh {
  width: 100%; background: #fff; color: #007AFF;
  border: 1px solid #007AFF; border-radius: 8px;
  padding: 10px 0; font-size: 15px;
}
.btn-refresh:active { background: #f0f7ff; }
