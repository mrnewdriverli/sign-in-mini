/* 签到表单页样式 */
.container {
  padding: 30px 20px;
}

.card {
  background: #fff;
  border-radius: 12px;
  padding: 24px 20px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 20px;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 28px;
}

.form-group {
  margin-bottom: 20px;
}

.form-label {
  font-size: 15px;
  color: #555;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 44px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 14px;
  font-size: 15px;
  box-sizing: border-box;
  background: #fafafa;
}

.form-input:focus {
  border-color: #007AFF;
  background: #fff;
}

.submit-btn {
  width: 100%;
  margin-top: 16px;
}
