/* 管理员验证 */
.auth-card {
  background: #fff;
  border-radius: 12px;
  padding: 40px 24px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  text-align: center;
}
.auth-icon { font-size: 48px; margin-bottom: 16px; }
.auth-title { font-size: 20px; font-weight: 600; color: #333; margin-bottom: 8px; }
.auth-desc { font-size: 14px; color: #999; margin-bottom: 24px; }
.auth-input {
  width: 100%;
  height: 46px;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  padding: 0 14px;
  font-size: 15px;
  text-align: center;
  box-sizing: border-box;
  margin-bottom: 16px;
}
.auth-input:focus { border-color: #007AFF; }
.btn-auth {
  width: 100%;
  background: #007AFF;
  color: #fff;
  border-radius: 8px;
  padding: 12px 0;
  font-size: 16px;
}
.btn-auth:active { opacity: 0.85; }
.auth-hint { font-size: 12px; color: #bbb; margin-top: 14px; }

/* 管理页 */
.container { padding: 30px 20px; }
.header { text-align: center; margin-bottom: 24px; }
.header-title { font-size: 24px; font-weight: 600; color: #333; margin-bottom: 8px; }
.header-desc { font-size: 15px; color: #007AFF; font-weight: 500; }

.btn-export {
  width: 100%; background: #007AFF; color: #fff;
  border-radius: 10px; padding: 14px 0; font-size: 16px;
  margin-bottom: 20px; border: none;
}
.btn-export:active { opacity: 0.85; }

.list-section { background: #fff; border-radius: 12px; overflow: hidden; }
.list-item {
  display: flex; align-items: center;
  padding: 14px 16px; border-bottom: 1px solid #f5f5f5;
}
.list-item:last-child { border-bottom: none; }

.item-index {
  width: 28px; height: 28px; background: #007AFF; color: #fff;
  border-radius: 50%; font-size: 13px;
  display: flex; align-items: center; justify-content: center;
  margin-right: 12px; flex-shrink: 0;
}
.item-info { flex: 1; }
.item-name { font-size: 16px; font-weight: 500; color: #333; margin-bottom: 3px; }
.item-dept { font-size: 13px; color: #999; font-weight: 400; }
.item-time { font-size: 12px; color: #aaa; }
.item-badge { padding: 4px 10px; border-radius: 12px; font-size: 12px; flex-shrink: 0; }
.badge-ok { background: #e8f5e9; color: #2e7d32; }

.empty { display: flex; flex-direction: column; align-items: center; padding-top: 60px; }
.empty-icon { font-size: 48px; margin-bottom: 12px; }
.empty-text { font-size: 15px; color: #bbb; }

.btn-refresh {
  width: 100%; background: #fff; color: #007AFF;
  border: 1px solid #007AFF; border-radius: 10px;
  padding: 12px 0; font-size: 15px; margin-top: 16px;
}
.btn-refresh:active { background: #f0f7ff; }
