/* 核销页样式 */
.container {
  padding: 30px 20px;
}

.header {
  text-align: center;
  margin-bottom: 24px;
}

.header-title {
  font-size: 24px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.header-desc {
  font-size: 14px;
  color: #999;
}

/* 扫码按钮 */
.btn-scan {
  width: 100%;
  background: linear-gradient(135deg, #007AFF, #00c6ff);
  color: #fff;
  border-radius: 12px;
  padding: 18px 0;
  font-size: 18px;
  font-weight: 500;
  margin-bottom: 20px;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 15px rgba(0, 122, 255, 0.3);
}

.btn-scan:active {
  opacity: 0.85;
}

.btn-scan[disabled] {
  opacity: 0.6;
}

.scan-icon {
  font-size: 22px;
  margin-right: 8px;
}

/* 导出按钮 */
.btn-export {
  width: 100%;
  background: #fff;
  color: #007AFF;
  border: 1px solid #007AFF;
  border-radius: 10px;
  padding: 14px 0;
  font-size: 16px;
  margin-bottom: 24px;
}

.btn-export:active {
  background: #f0f7ff;
}

/* 结果卡片 */
.result-card {
  border-radius: 10px;
  padding: 16px 20px;
  margin-bottom: 20px;
  white-space: pre-line;
}

.result-success {
  background: #e8f5e9;
  border: 1px solid #a5d6a7;
}

.result-fail {
  background: #ffebee;
  border: 1px solid #ef9a9a;
}

.result-text {
  font-size: 15px;
  line-height: 1.6;
}

/* 核销列表 */
.list-section {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
}

.list-title {
  font-size: 17px;
  font-weight: 600;
  color: #333;
  padding: 16px 16px 4px;
}

.list-total {
  font-size: 13px;
  color: #999;
  padding: 0 16px 12px;
  border-bottom: 1px solid #f0f0f0;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 14px 16px;
  border-bottom: 1px solid #f5f5f5;
}

.list-item:last-child {
  border-bottom: none;
}

.item-index {
  width: 28px;
  height: 28px;
  background: #007AFF;
  color: #fff;
  border-radius: 50%;
  font-size: 13px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12px;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
}

.item-name {
  font-size: 16px;
  font-weight: 500;
  color: #333;
  margin-bottom: 2px;
}

.item-dept {
  font-size: 13px;
  color: #999;
}

.item-time {
  font-size: 12px;
  color: #4caf50;
  flex-shrink: 0;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 40px;
}

.empty-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.empty-text {
  font-size: 15px;
  color: #bbb;
}
