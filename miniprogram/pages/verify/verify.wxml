<!-- 签到管理页 - 管理员专用 -->
<view class="container">

  <!-- 未验证 -->
  <view wx:if="{{!authed}}" class="auth-card">
    <view class="auth-icon">🔐</view>
    <view class="auth-title">管理员验证</view>
    <view class="auth-desc">请输入管理员密码</view>
    <input class="auth-input" type="password" placeholder="管理员密码" value="{{pwdInput}}" bindinput="onPwdInput" bindconfirm="checkPwd"/>
    <button class="btn-auth" bindtap="checkPwd">验证进入</button>
    <view class="auth-hint">默认密码：admin888</view>
  </view>

  <!-- 已验证 -->
  <view wx:if="{{authed}}">
    <view class="header">
      <view class="header-title">📊 签到管理</view>
      <view class="header-desc">已签到 {{total}} 人</view>
    </view>

    <button class="btn-export" bindtap="exportCSV">📥 导出签到 Excel</button>

    <view class="list-section" wx:if="{{records.length > 0}}">
      <view class="list-item" wx:for="{{records}}" wx:key="_id">
        <view class="item-index">{{index + 1}}</view>
        <view class="item-info">
          <view class="item-name">{{item.name}}<text class="item-dept"> · {{item.department}}</text></view>
          <view class="item-time">{{item.timeStr}}</view>
        </view>
        <view class="item-badge badge-ok">已签到</view>
      </view>
    </view>

    <view wx:else class="empty">
      <text class="empty-icon">📭</text>
      <text class="empty-text">{{loading ? '加载中...' : '暂无签到记录'}}</text>
    </view>

    <button wx:if="{{records.length > 0}}" class="btn-refresh" bindtap="loadRecords">🔄 刷新列表</button>
  </view>

</view>
